# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/zoulkiful_brand"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_SECRET="your-secret-key-min-32-chars-change-in-production"

# ─── Moneroo Payment Gateway ──────────────────────────────────────────────────
# Get your keys at https://moneroo.io
MONEROO_API_KEY="your_moneroo_api_key"
MONEROO_SECRET_KEY="your_moneroo_secret_key"
NEXT_PUBLIC_MONEROO_PUBLIC_KEY="your_moneroo_public_key"

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
# Example using Gmail — use App Password (not your real password)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-password"
EMAIL_FROM="Zoulkiful Soumaila <your-email@gmail.com>"

# ─── Notion Content URLs (sent after purchase) ───────────────────────────────
NOTION_STARTER_URL="https://notion.so/your-starter-workspace"
NOTION_SAAS_URL="https://notion.so/your-saas-workspace"
NOTION_COACHING_URL="https://notion.so/your-coaching-workspace"

# ─── WhatsApp ─────────────────────────────────────────────────────────────────
